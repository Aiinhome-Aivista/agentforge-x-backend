# ─────────────────────────────────────────────────────────────
# Process Agentifier — Backend Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────


# ── Mistral LLM ───────────────────────────────────────────────
MISTRAL_API_KEY=IotlgX9OC7gWRj0WqHuT5xdhT1LNkNne
# Options: mistral-large-latest (best), mistral-small-latest (cheaper/faster)
MISTRAL_MODEL=mistral-small-latest


# ── ArangoDB ──────────────────────────────────────────────────
ARANGO_HOST=https://409940ccdebc.arangodb.cloud:8529
ARANGO_DB=agent
ARANGO_USERNAME=root
ARANGO_PASSWORD=HjzEYC4ilPIudYvQRPdR


# ── Flask ─────────────────────────────────────────────────────
FLASK_ENV=production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-random-secret-key
FLASK_HOST=127.0.0.1
FLASK_PORT=3006


# ── CORS — Frontend Origins ───────────────────────────────────
# Comma-separated list of allowed frontend URLs (no trailing slash).
# Examples:
#   Single domain:    https://app.yourdomain.com
#   Multiple:         https://app.yourdomain.com,http://192.168.1.50:3000
#   Local dev:        http://localhost:3000,http://localhost:5173
#   Allow all (dev):  *
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173


# ── Upload Limits ─────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50


# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO


# ── Gunicorn (Linux only) ─────────────────────────────────────
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=180
GUNICORN_ACCESS_LOG=-
GUNICORN_ERROR_LOG=-


# ── Waitress (Windows only) ───────────────────────────────────
WAITRESS_THREADS=4

BASE_URL=http://122.163.121.176:3006